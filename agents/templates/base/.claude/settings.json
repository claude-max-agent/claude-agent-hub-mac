{
  "language": "japanese",
  "includeGitInstructions": false,
  "env": {},
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/block-dangerous.sh\"",
            "timeout": 5,
            "statusMessage": "Checking command safety..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/auto-lint.sh\"",
            "timeout": 30,
            "statusMessage": "Running auto-lint..."
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6",
  "reasoning_effort": "high"
}
