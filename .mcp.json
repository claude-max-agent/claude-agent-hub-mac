{
  "mcpServers": {
    "memory-engine": {
      "command": "python3",
      "args": ["-m", "memory_engine.cli", "serve"],
      "cwd": "services/memory-engine",
      "env": {
        "MEMORY_ENGINE_DB": "${HOME}/.claude/memory.db",
        "MEMORY_ENGINE_BACKEND": "mlx",
        "OLLAMA_URL": "http://localhost:11434"
      }
    }
  }
}
